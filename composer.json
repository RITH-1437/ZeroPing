{
  "name": "rith-1437/zero-ping",
  "description": "ZeroPing is a lightweight, modern PHP framework with a clean MVC architecture, dependency injection, multi-driver ORM, validation, caching, queues, a task scheduler, and batteries-included CLI tooling. New projects run on SQLite with zero configuration.",
  "type": "project",
  "license": "MIT",
  "keywords": [
    "php",
    "framework",
    "mvc",
    "orm",
    "router",
    "validation",
    "dependency-injection",
    "queue",
    "scheduler",
    "cache",
    "cli",
    "sqlite",
    "mysql",
    "postgresql",
    "zeroping"
  ],
  "homepage": "https://github.com/RITH-1437/ZeroPing",
  "authors": [
    {
      "name": "Rin Nairith",
      "email": "nairithrin143@gmail.com",
      "role": "Creator & Maintainer"
    }
  ],
  "support": {
    "issues": "https://github.com/RITH-1437/ZeroPing/issues",
    "source": "https://github.com/RITH-1437/ZeroPing",
    "docs": "https://github.com/RITH-1437/ZeroPing/tree/main/docs",
    "chat": "https://github.com/RITH-1437/ZeroPing/discussions"
  },
  "require": {
    "php": ">=8.1 <8.6",
    "composer-runtime-api": "^2.0",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "ext-mbstring": "*",
    "ext-json": "*",
    "ext-ctype": "*",
    "ext-tokenizer": "*",
    "ext-fileinfo": "*",
    "ext-openssl": "*",
    "ext-hash": "*"
  },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Zeroping\\Support\\": "packages/zeroping/support/src",
            "Zeroping\\Queue\\": "packages/zeroping/queue/src"
        },
        "files": [
            "app/Helpers/helpers.php"
        ]
    },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "bin": [
    "zero"
  ],
    "scripts": {
        "post-create-project-cmd": [
            "@php scripts/post-create-project.php"
        ],
        "post-autoload-dump": [
            "@php scripts/discover-packages.php"
        ],
    "doctor": "@php zero doctor",
    "install-wizard": "@php zero install",
    "serve": "@php zero serve",
    "test": "phpunit",
    "lint": "phpcs",
    "lint:fix": "phpcbf"
  },
  "scripts-descriptions": {
    "doctor": "Verify the ZeroPing installation and environment.",
    "install-wizard": "Run the interactive ZeroPing installation wizard.",
    "serve": "Start the ZeroPing development server.",
    "test": "Run the PHPUnit test suite.",
    "lint": "Check coding standards with PHP_CodeSniffer.",
    "lint:fix": "Automatically fix coding standard violations."
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "allow-plugins": {}
  },
  "extra": {
    "branch-alias": {
      "dev-main": "1.2.x-dev"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require-dev": {
    "phpunit/phpunit": "^13.2",
    "squizlabs/php_codesniffer": "^3.10"
  }
}
