{
  "name": "rith-1437/zeroping",
  "description": "ZeroPing is a lightweight, modern PHP framework with a clean MVC architecture, dependency injection, ORM, validation, caching, queues, a task scheduler, and batteries-included CLI tooling. Install it to build production applications.",
  "type": "project",
  "license": "MIT",
  "keywords": [
    "php",
    "framework",
    "mvc",
    "orm",
    "router",
    "validation",
    "dependency-injection",
    "queue",
    "scheduler",
    "cache",
    "cli",
    "zeroping"
  ],
  "homepage": "https://github.com/RITH-1437/ZeroPing",
  "authors": [
    {
      "name": "Rin Nairith",
      "email": "nairithrin143@gmail.com",
      "role": "Creator"
    }
  ],
  "support": {
    "issues": "https://github.com/RITH-1437/ZeroPing/issues",
    "source": "https://github.com/RITH-1437/ZeroPing",
    "docs": "https://github.com/RITH-1437/ZeroPing/tree/main/docs"
  },
  "require": {
    "php": ">=8.1",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*",
    "ext-mbstring": "*",
    "ext-json": "*",
    "ext-ctype": "*",
    "ext-tokenizer": "*",
    "ext-fileinfo": "*",
    "ext-openssl": "*",
    "ext-hash": "*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "bin": [
    "zero"
  ],
  "scripts": {
    "post-create-project-cmd": [
      "@php scripts/post-create-project.php"
    ]
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "allow-plugins": {}
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require-dev": {
    "phpunit/phpunit": "^13.2"
  }
}
