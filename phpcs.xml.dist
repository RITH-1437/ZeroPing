<?xml version="1.0"?>
<ruleset name="ZeroPing">
    <description>ZeroPing Framework coding standard (PSR-12)</description>

    <rule ref="PSR12"/>

    <!--
        Warnings (e.g. long lines in framework/sample code) are advisory and
        should not fail the quality gate; only errors do.
    -->
    <config name="ignore_warnings_on_exit" value="1"/>

    <!--
        The test suite legitimately uses snake_case test method names and
        inline fixture/model classes, which conflict with PSR1 naming and
        single-class-per-file rules. Relax those sniffs for tests only.
    -->
    <rule ref="PSR1.Methods.CamelCapsMethodName">
        <exclude-pattern>*tests/*</exclude-pattern>
    </rule>
    <rule ref="PSR1.Classes.ClassDeclaration.MultipleClasses">
        <exclude-pattern>*tests/*</exclude-pattern>
    </rule>
    <rule ref="PSR1.Files.SideEffects.FoundWithSymbols">
        <exclude-pattern>*tests/*</exclude-pattern>
        <exclude-pattern>*public/*</exclude-pattern>
        <exclude-pattern>*config/*</exclude-pattern>
    </rule>
    <rule ref="PSR12.Properties.ConstantVisibility.NotFound">
        <exclude-pattern>*tests/*</exclude-pattern>
    </rule>

    <!--
        Long lines are a stylistic preference, not a defect. Relax the
        line-length sniff for generated/cache output, CLI starter scripts,
        environment bootstrap and the test suite (which routinely has long
        fixture/assertion lines). The framework library under app/ keeps
        the 120-column limit.
    -->
    <rule ref="Generic.Files.LineLength">
        <exclude-pattern>*bootstrap/cache/*</exclude-pattern>
        <exclude-pattern>*scripts/*</exclude-pattern>
        <exclude-pattern>*public/*</exclude-pattern>
        <exclude-pattern>*config/*</exclude-pattern>
        <exclude-pattern>*tests/*</exclude-pattern>
        <!--
            The CLI definition tables (command => description/options arrays) and
            banner/HTML heredocs in app/Core/Console are structurally long and
            must not be re-wrapped (it risks breaking the console). Carve
            them out of the line-length sniff; everything else in app/
            keeps the 120-column limit.
        -->
        <exclude-pattern>*app/Core/Console/*</exclude-pattern>
    </rule>

    <file>app</file>
    <file>config</file>
    <file>bootstrap</file>
    <file>scripts</file>
    <file>tests</file>
    <file>public</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/views/*</exclude-pattern>
    <exclude-pattern>*/Templates/*</exclude-pattern>
    <exclude-pattern>*bootstrap/cache/*</exclude-pattern>

    <arg name="colors"/>
    <arg value="s"/>
    <ini name="memory_limit" value="256M"/>
</ruleset>
