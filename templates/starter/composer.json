{
    "name": "zeroping/{{PROJECT_SLUG}}",
    "description": "{{ project_description }}",
    "type": "project",
    "license": "MIT",
    "keywords": ["zeroping", "php", "framework"],
    "require": {
        "php": ">=8.1 <8.6",
        "rith-1437/zero-ping": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "serve": "@php zero serve",
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
