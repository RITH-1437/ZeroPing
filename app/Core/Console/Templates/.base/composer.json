{
    "name": "{{ vendor }}/{{ project_slug }}",
    "description": "{{ project_description }}",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "rith-1437/zeroping": "dev-main"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"echo 'Dependencies installed. Run: php zero migrate\\n';\""
        ]
    }
}
