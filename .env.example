APP_NAME=ZeroPing
APP_ENV=development
APP_DEBUG=true

# Database — new projects default to SQLite (zero configuration).
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# Uncomment and adjust to use MySQL:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=zero_ping
# DB_USERNAME=root
# DB_PASSWORD=
# DB_CHARSET=utf8mb4

# Uncomment and adjust to use PostgreSQL:
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=zero_ping
# DB_USERNAME=postgres
# DB_PASSWORD=
# DB_CHARSET=utf8
