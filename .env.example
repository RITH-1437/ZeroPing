APP_NAME=ZeroPing
APP_ENV=development
APP_DEBUG=true

# Project metadata — automatically set during scaffolding.
PROJECT_SLUG=zero-ping
STARTER_TYPE=empty
STARTER_LABEL=Empty Starter
STARTER_DESCRIPTION=A lightweight starter ready for development.
FRAMEWORK_VERSION=2.0.0

# Documentation URL shown on the default welcome page.
DOCS_URL=https://zero-ping.duckdns.org

# Database — new projects default to SQLite (zero configuration).
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# Uncomment and adjust to use MySQL:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=zero_ping
# DB_USERNAME=root
# DB_PASSWORD=
# DB_CHARSET=utf8mb4

# Uncomment and adjust to use PostgreSQL:
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=zero_ping
# DB_USERNAME=postgres
# DB_PASSWORD=
# DB_CHARSET=utf8
